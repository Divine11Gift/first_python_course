<!DOCTYPE html>
<html lang="=en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale+1.0">
        <title>WorldPlate - International Recipes</title>
        <linkn href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;400&family=DM+San:wght@300;400;500&display=swap" rel="stylesheet">
        <style>
            :root {
                --cream:#FAF7F2;
                --warm-white: #FFFDF9;
                --charcoal: #1C1917;
                --ink: #2D2926;
                --muted: #7A7370;
                --border: #E8E2D9;
                --accent: #C1440e;
                --accent-light: #f5e8e2;
                --gold: #b8860b;
                --gold-light: #fdf8ee;
                --green: #2d6a4f;
                --green-light: #eaf3ee;
                --tag-bg: #f0ece5;
                --shadow: 0 2px 20px rgba(28,25,23,0.08);
                --shadow-hover: 0 8px 40px rgba(28,25,23,0.14);
                --radius: 12px;
                --radius-lg: 18px;
            }

            * { margin: 0; padding:0; box-sizing: border-box; }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--cream);
                color: var(--ink);
                min-height: 100vh;
                overflow-x: hidden;
            }

            /* NAV */
            nav{
                position: sticky; top: 0; z-index: 100;
                background: rgba(250,247,242,0.95);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid var(--border);
                padding: 0 2rem;
                display: flex; align-items: center; justify-content: space-between;
                height: 64px;
            }
    
            .logo{
                font-family: 'playfair display', serif;
                font-size: 1.5rem;
                color: var(--charcoal);
                letter-spacing: -0.02em;
            }

            .logo span{ color: var(--accent); font-style: italic; }

            .nav-right { display: flex; align-items: center; gap: 1rem; }
            
            .search-bar { display: flex; align-items: center;
            background: #E8E2D9; border: 1px solid var(--border);
         border-radius: 999px; padding: 6px 14px; gap: 8px;
         transition: border-color o.2s; 
        }
        .search-bar:focus-within {border-color: var(--accent); }
        .search-bar input { border: none; background: transperent; font-family: 'DM Sans', sans-serif; font-size: 14px; width: 200px; color: var(--ink); }
        .search-bar svg {color: var(--muted); flex-shrink: 0; }

        .cart-btn {
            position: relative; cursor: pointer;
            background: var(--charcoal); color: var(--warm-white);
            border: none; border-radius: 999px;
            padding: 8px 18px 8px 14px;
            display: flex; align-items: center; gap: 8px;
            font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500;
            transition: background 0.2s, transform 0.15s;
        }
        .cart-btn:hover {background: var(--accent); transform: scale(1.02);}
        .cart-badge {
    position: absolute; top: -6px; right: -6px;
    background: var(--accent); color: white;
    width: 20px; height: 20px; border-radius: 50%;
    font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    display: none;
  }
  
  /*HERO */ 
  .hero {
    padding: 5rem 2rem 3rem;
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;
  }
 
  .hero-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    line-height: 1.15;
    color: var(--charcoal);
    margin-bottom: 1rem;
  }
 
  .hero-text h1 em { color: var(--accent); font-style: italic; }
 
  .hero-text p {
    color: var(--muted); font-size: 1.05rem; line-height: 1.7;
    max-width: 420px; margin-bottom: 2rem;
  }
 
  .hero-stats { display: flex; gap: 2rem; }
  .stat { }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--charcoal); }
  .stat-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
 
  .hero-visual {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
    transform: rotate(2deg);
  }
 
  .hero-card {
    border-radius: var(--radius);
    overflow: hidden;
    height: 180px;
    position: relative;
    display: flex; align-items: flex-end;
  }
  .hero-card:nth-child(1) { grid-row: span 2; height: auto; }
  .hero-card .hc-bg {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem;
  }
  .hero-card .hc-label {
    position: relative; z-index: 1;
    background: rgba(28,25,23,0.75);
    color: white; width: 100%; padding: 10px 14px;
    font-size: 13px; font-weight: 500;
    backdrop-filter: blur(4px);
  }

/* CATEGORIES */
 .section { max-width: 1200px; margin: 0 auto; padding: 2rem; }
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; color: var(--charcoal);
  }
 
  .category-pills {
    display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 2.5rem;
  }
 
  .pill {
    padding: 8px 18px; border-radius: 999px;
    border: 1px solid var(--border);
    background: white; color: var(--muted);
    font-size: 14px; font-weight: 500; cursor: pointer;
    transition: all 0.2s;
    display: flex; align-items: center; gap: 6px;
  }
 
  .pill:hover { border-color: var(--accent); color: var(--accent); }
  .pill.active {
    background: var(--charcoal); color: white;
    border-color: var(--charcoal);
  }
 
  /* RECIPE GRID */
  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }
 
  .recipe-card {
    background: white; border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: box-shadow 0.25s, transform 0.25s;
    cursor: pointer;
  }
 
  .recipe-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }
 
  .recipe-card.hidden { display: none; }
 
  .recipe-img {
    height: 200px; background: var(--tag-bg);
    display: flex; align-items: center; justify-content: center;
    font-size: 5rem; position: relative;
  }
 
  .recipe-flag {
    position: absolute; top: 12px; left: 12px;
    background: rgba(255,255,255,0.9); backdrop-filter: blur(8px);
    border-radius: 999px; padding: 4px 10px;
    font-size: 12px; font-weight: 500; color: var(--charcoal);
    display: flex; align-items: center; gap: 5px;
  }
 
  .recipe-difficulty {
    position: absolute; top: 12px; right: 12px;
    border-radius: 999px; padding: 4px 10px;
    font-size: 11px; font-weight: 600;
  }
  .diff-easy { background: var(--green-light); color: var(--green); }
  .diff-medium { background: var(--gold-light); color: var(--gold); }
  .diff-hard { background: var(--accent-light); color: var(--accent); }
 
  .recipe-body { padding: 1.25rem; }
 
  .recipe-cuisine {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--accent); font-weight: 600; margin-bottom: 6px;
  }
 
  .recipe-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem; color: var(--charcoal);
    margin-bottom: 8px; line-height: 1.3;
  }
 
  .recipe-desc {
    font-size: 13px; color: var(--muted); line-height: 1.6;
    margin-bottom: 1rem;
  }
 
  .recipe-meta {
    display: flex; gap: 16px; margin-bottom: 1rem;
    font-size: 12px; color: var(--muted);
  }
 
  .recipe-meta span { display: flex; align-items: center; gap: 5px; }
 
  .recipe-actions {
    display: flex; gap: 8px; align-items: center;
  }
 
  .btn-view {
    flex: 1; padding: 9px;
    background: var(--tag-bg); border: none; border-radius: var(--radius);
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
    color: var(--charcoal); cursor: pointer;
    transition: background 0.2s;
  }
  .btn-view:hover { background: var(--border); }
 
  .btn-add {
    padding: 9px 16px;
    background: var(--charcoal); border: none; border-radius: var(--radius);
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
    color: white; cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-add:hover { background: var(--accent); }
  .btn-add.added { background: var(--green); }
 
  /* MODAL */
  .modal-backdrop {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(28,25,23,0.6); backdrop-filter: blur(4px);
    align-items: center; justify-content: center;
    padding: 2rem;
  }
  .modal-backdrop.open { display: flex; }
 
  .modal {
    background: white; border-radius: var(--radius-lg);
    max-width: 680px; width: 100%; max-height: 85vh;
    overflow-y: auto;
    box-shadow: var(--shadow-hover);
    animation: slideUp 0.25s ease;
  }
 
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
 
  .modal-img {
    height: 260px; background: var(--tag-bg);
    display: flex; align-items: center; justify-content: center;
    font-size: 7rem; position: relative;
  }
 
  .modal-close {
    position: absolute; top: 14px; right: 14px;
    width: 34px; height: 34px; border-radius: 50%;
    background: rgba(255,255,255,0.9); border: none; cursor: pointer;
    font-size: 18px; display: flex; align-items: center; justify-content: center;
    color: var(--charcoal);
    transition: background 0.2s;
  }
  .modal-close:hover { background: white; }
 
  .modal-body { padding: 1.75rem; }
  .modal-cuisine { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); font-weight: 600; margin-bottom: 6px; }
  .modal-name { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--charcoal); margin-bottom: 8px; }
  .modal-desc { color: var(--muted); line-height: 1.7; margin-bottom: 1.5rem; }
 
  .modal-meta { display: flex; gap: 20px; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .meta-chip {
    background: var(--tag-bg); border-radius: 999px;
    padding: 6px 14px; font-size: 13px; color: var(--charcoal);
    display: flex; align-items: center; gap: 6px;
  }
 
  .ingredients-section h3 {
    font-family: 'Playfair Display', serif; font-size: 1.2rem;
    color: var(--charcoal); margin-bottom: 1rem;
  }
 
  .ingredients-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 8px; margin-bottom: 1.5rem;
  }
 
  .ingredient-item {
    background: var(--cream); border-radius: var(--radius);
    padding: 10px 14px;
    font-size: 13px;
  }
  .ingredient-item strong { color: var(--charcoal); display: block; }
  .ingredient-item span { color: var(--muted); font-size: 12px; }
 
  .steps-section h3 { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--charcoal); margin-bottom: 1rem; }
 
  .step-item {
    display: flex; gap: 14px; margin-bottom: 14px; align-items: flex-start;
  }
 
  .step-num {
    flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
    background: var(--charcoal); color: white;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; margin-top: 1px;
  }
 
  .step-text { font-size: 14px; color: var(--ink); line-height: 1.65; }
 
  .modal-footer {
    padding: 1.25rem 1.75rem;
    border-top: 1px solid var(--border);
    display: flex; gap: 12px; align-items: center;
    background: var(--warm-white);
  }
 
  .modal-footer .btn-add {
    flex: 1; padding: 12px;
    font-size: 15px;
  }
 
  /* CART SIDEBAR */
  .cart-overlay {
    display: none; position: fixed; inset: 0; z-index: 300;
    background: rgba(28,25,23,0.5);
  }
  .cart-overlay.open { display: block; }
 
  .cart-sidebar {
    position: fixed; top: 0; right: -420px; width: 400px; height: 100vh; z-index: 301;
    background: white;
    display: flex; flex-direction: column;
    transition: right 0.3s cubic-bezier(0.4,0,0.2,1);
    box-shadow: -8px 0 40px rgba(28,25,23,0.12);
  }
 
  .cart-sidebar.open { right: 0; }
 
  .cart-header {
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }

  .cart-title { font-family: 'playfair Display', serif; font-size: 1.4rem; color: var(--charcoal);}

   .cart-close {
    width: 34px; height: 34px; border-radius: 50%;
    background: var(--tag-bg); border: none; cursor: pointer;
    font-size: 18px; display: flex; align-items: center; justify-content: center;
    color: var(--charcoal); transition: background 0.2s;
  }
  .cart-close:hover { background: var(--border); }
 
  .cart-items { flex: 1; overflow-y: auto; padding: 1.25rem; }
 
  .cart-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    height: 100%; text-align: center; color: var(--muted);
    gap: 1rem;
  }
  .cart-empty .empty-icon { font-size: 3rem; }
  .cart-empty p { font-size: 15px; }
 
  .cart-item {
    display: flex; gap: 14px; padding: 14px 0;
    border-bottom: 1px solid var(--border); align-items: center;
  }
 
  .cart-item-emoji { font-size: 2.5rem; flex-shrink: 0; }
 
  .cart-item-info { flex: 1; }
  .cart-item-name { font-weight: 500; font-size: 14px; color: var(--charcoal); margin-bottom: 3px; }
  .cart-item-cuisine { font-size: 12px; color: var(--muted); }
 
  .cart-item-qty {
    display: flex; align-items: center; gap: 10px;
  }
  .qty-btn {
    width: 26px; height: 26px; border-radius: 50%;
    border: 1px solid var(--border); background: white;
    cursor: pointer; font-size: 15px; font-weight: 500;
    display: flex; align-items: center; justify-content: center;
    color: var(--charcoal); transition: border-color 0.2s, background 0.2s;
  }
  .qty-btn:hover { border-color: var(--charcoal); background: var(--tag-bg); }
  .qty-num { font-size: 14px; font-weight: 600; min-width: 18px; text-align: center; }
 
  .cart-remove {
    width: 28px; height: 28px; border-radius: 50%;
    background: transparent; border: none; cursor: pointer;
    font-size: 16px; color: var(--muted); transition: color 0.2s, background 0.2s;
    display: flex; align-items: center; justify-content: center;
  }
  .cart-remove:hover { background: var(--accent-light); color: var(--accent); }
 
  .cart-footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--border);
    background: var(--cream);
  }
 
  .cart-summary { margin-bottom: 1rem; }
  .cart-summary-row {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 14px; color: var(--muted); margin-bottom: 8px;
  }
  .cart-summary-row.total {
    font-size: 16px; font-weight: 600; color: var(--charcoal);
    padding-top: 10px; border-top: 1px solid var(--border);
  }
 
  .btn-checkout {
    width: 100%; padding: 14px;
    background: var(--charcoal); border: none; border-radius: var(--radius);
    font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500;
    color: white; cursor: pointer;
    transition: background 0.2s;
  }
  .btn-checkout:hover { background: var(--accent); }
 
  /* FOOTER */
  footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding: 2.5rem 2rem;
    max-width: 1200px; margin-left: auto; margin-right: auto;
    display: flex; align-items: center; justify-content: space-between;
    color: var(--muted); font-size: 13px;
  }
 
  .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--charcoal); }
  .footer-logo span { color: var(--accent); font-style: italic; }
 
  /* Notification */
  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--charcoal); color: white;
    padding: 12px 20px; border-radius: 999px;
    font-size: 14px; font-weight: 500;
    z-index: 400;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }
 
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .ingredients-grid { grid-template-columns: 1fr; }
    .cart-sidebar { width: 100%; right: -100%; }
    nav { padding: 0 1rem; }
    .search-bar input { width: 130px; }
  }
            </style>
    </linkn>
    </head>

    <!-- NAV -->
     <nav>
        <div class="logo">World<span>Plate</span></div>>
        <div class="nav-right">
            <div class="search-bar">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" id="searchInput" placeholder="Search dishes…" oninput="filterRecipes()">
    </div>
    <button class="cart-btn" onclick="openCart()">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      Cart
      <div class="cart-badge" id="cartBadge">0</div>
    </button>
  </div>
</nav>
 
<!-- HERO -->
