let cart = {};
let activeRecipe = null;
let activeCuisine = 'all';
let searchQuery = '';
 
function renderGrid() {
  const grid = document.getElementById('recipeGrid');
  grid.innerHTML = '';
  recipes.forEach(r => {
    const show = (activeCuisine === 'all' || r.cuisine === activeCuisine) &&
      (r.name.toLowerCase().includes(searchQuery) || r.cuisine.toLowerCase().includes(searchQuery) || r.country.toLowerCase().includes(searchQuery));
    const inCart = cart[r.id];
    const card = document.createElement('div');
    card.className = 'recipe-card' + (show ? '' : ' hidden');
    card.innerHTML = `
      <div class="recipe-img" style="background:${r.bg}">
        <span style="font-size:5rem">${r.emoji}</span>
        <div class="recipe-flag">${r.country}</div>
        <div class="recipe-difficulty diff-${r.difficulty.toLowerCase()}">${r.difficulty}</div>
      </div>
      <div class="recipe-body">
        <div class="recipe-cuisine">${r.cuisine}</div>
        <div class="recipe-name">${r.name}</div>
        <div class="recipe-desc">${r.desc}</div>
        <div class="recipe-meta">
          <span>⏱ ${r.time}</span>
          <span>👥 Serves ${r.servings}</span>
          <span>📋 ${r.ingredients.length} ingredients</span>
        </div>
        <div class="recipe-actions">
          <button class="btn-view" onclick="openModal(${r.id})">View Recipe</button>
          <button class="btn-add ${inCart ? 'added' : ''}" onclick="addToCart(${r.id}, event)">
            ${inCart ? '✓ Added' : '+ Cart'}
          </button>
        </div>
      </div>`;
    grid.appendChild(card);
  });
}
 
function filterCuisine(cuisine, el) {
  activeCuisine = cuisine;
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  renderGrid();
}
 
function filterRecipes() {
  searchQuery = document.getElementById('searchInput').value.toLowerCase();
  renderGrid();
}
 
function openModal(id) {
  const r = recipes.find(x => x.id === id);
  if (!r) return;
  activeRecipe = r;
  document.getElementById('modalImg').style.background = r.bg;
  document.getElementById('modalImg').innerHTML = `<span style="font-size:7rem">${r.emoji}</span><button class="modal-close" onclick="closeModalDirect()">✕</button>`;
  document.getElementById('modalCuisine').textContent = r.cuisine + ' · ' + r.country;
  document.getElementById('modalName').textContent = r.name;
  document.getElementById('modalDesc').textContent = r.desc;
  document.getElementById('modalMeta').innerHTML = `
    <div class="meta-chip">⏱ ${r.time}</div>
    <div class="meta-chip">👥 Serves ${r.servings}</div>
    <div class="meta-chip">📋 ${r.ingredients.length} ingredients</div>
    <div class="meta-chip diff-${r.difficulty.toLowerCase()}">${r.difficulty}</div>`;
  document.getElementById('modalIngredients').innerHTML = r.ingredients.map(i =>
    `<div class="ingredient-item"><strong>${i.name}</strong><span>${i.amount}</span></div>`).join('');
  document.getElementById('modalSteps').innerHTML = r.steps.map((s, i) =>
    `<div class="step-item"><div class="step-num">${i+1}</div><div class="step-text">${s}</div></div>`).join('');
  const addBtn = document.getElementById('modalAddBtn');
  if (cart[r.id]) { addBtn.textContent = '✓ In Cart'; addBtn.classList.add('added'); }
  else { addBtn.textContent = '+ Add to Cart'; addBtn.classList.remove('added'); }
  document.getElementById('modalBackdrop').classList.add('open');
  document.body.style.overflow = 'hidden';
}
 
function closeModal(e) {
  if (e.target === document.getElementById('modalBackdrop')) closeModalDirect();
}
 
function closeModalDirect() {
  document.getElementById('modalBackdrop').classList.remove('open');
  document.body.style.overflow = '';
}
 
function addFromModal() {
  if (!activeRecipe) return;
  addToCart(activeRecipe.id);
  const btn = document.getElementById('modalAddBtn');
  btn.textContent = '✓ In Cart'; btn.classList.add('added');
}
 
function addToCart(id, e) {
  if (e) e.stopPropagation();
  const r = recipes.find(x => x.id === id);
  if (cart[id]) { cart[id].qty++; }
  else { cart[id] = { ...r, qty: 1 }; }
  updateCartUI();
  renderGrid();
  showToast(`${r.emoji} ${r.name} added to cart`);
}
 
function removeFromCart(id) {
  delete cart[id];
  updateCartUI();
  renderGrid();
}
 
function changeQty(id, delta) {
  if (!cart[id]) return;
  cart[id].qty += delta;
  if (cart[id].qty <= 0) { delete cart[id]; }
  updateCartUI();
  renderGrid();
}
 
function updateCartUI() {
  const items = Object.values(cart);
  const totalQty = items.reduce((s, i) => s + i.qty, 0);
  const badge = document.getElementById('cartBadge');
  badge.textContent = totalQty;
  badge.style.display = totalQty > 0 ? 'flex' : 'none';
 
  const container = document.getElementById('cartItems');
  const footer = document.getElementById('cartFooter');
  const empty = document.getElementById('cartEmpty');
 
  if (items.length === 0) {
    container.innerHTML = '';
    container.appendChild(empty);
    empty.style.display = 'flex';
    footer.style.display = 'none';
    return;
  }
 
  empty.style.display = 'none';
  footer.style.display = 'block';
  container.innerHTML = items.map(item => `
    <div class="cart-item">
      <div class="cart-item-emoji">${item.emoji}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-cuisine">${item.cuisine} · ${item.country}</div>
      </div>
      <div class="cart-item-qty">
        <button class="qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
        <span class="qty-num">${item.qty}</span>
        <button class="qty-btn" onclick="changeQty(${item.id}, 1)">+</button>
      </div>
      <button class="cart-remove" onclick="removeFromCart(${item.id})" title="Remove">✕</button>
    </div>`).join('');
  container.appendChild(document.createElement('div'));
 
  document.getElementById('cartItemCount').textContent = `${items.length} recipe${items.length > 1 ? 's' : ''}`;
  document.getElementById('cartTotal').textContent = totalQty + (totalQty === 1 ? ' serving' : ' servings');
}
 
function openCart() {
  document.getElementById('cartSidebar').classList.add('open');
  document.getElementById('cartOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
 
function closeCart() {
  document.getElementById('cartSidebar').classList.remove('open');
  document.getElementById('cartOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
 
function checkout() {
  const items = Object.values(cart);
  if (!items.length) return;
  let text = "🌍 My WorldPlate Recipe List:\n\n";
  items.forEach(i => { text += `${i.emoji} ${i.name} (${i.cuisine}) × ${i.qty}\n`; });
  try { navigator.clipboard.writeText(text); } catch(e) {}
  showToast('📋 Recipe list copied to clipboard!');
}
 
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}
 
// Init
updateCartUI();
renderGrid();
</script>
