</footer>
 
<!-- RECIPE MODAL -->
<div class="modal-backdrop" id="modalBackdrop" onclick="closeModal(event)">
  <div class="modal" id="recipeModal">
    <div class="modal-img" id="modalImg">
      <button class="modal-close" onclick="closeModalDirect()">✕</button>
    </div>
    <div class="modal-body">
      <div class="modal-cuisine" id="modalCuisine"></div>
      <h2 class="modal-name" id="modalName"></h2>
      <p class="modal-desc" id="modalDesc"></p>
      <div class="modal-meta" id="modalMeta"></div>
      <div class="ingredients-section">
        <h3>Ingredients</h3>
        <div class="ingredients-grid" id="modalIngredients"></div>
      </div>
      <div class="steps-section" style="margin-top:1.5rem">
        <h3>How to Make It</h3>
        <div id="modalSteps"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-add" id="modalAddBtn" onclick="addFromModal()">
        + Add to Cart
      </button>
    </div>
  </div>
</div>
 
<!-- CART SIDEBAR -->
<div class="cart-overlay" id="cartOverlay" onclick="closeCart()"></div>
<div class="cart-sidebar" id="cartSidebar">
  <div class="cart-header">
    <div class="cart-title">Your Cart</div>
    <button class="cart-close" onclick="closeCart()">✕</button>
  </div>
  <div class="cart-items" id="cartItems">
    <div class="cart-empty" id="cartEmpty">
      <div class="empty-icon">🛒</div>
      <p>Your cart is empty.<br>Add some delicious recipes!</p>
    </div>
